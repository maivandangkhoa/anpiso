{
  "name": "anpiso",
  "private": true,
  "version": "0.0.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:3002": "lsof -ti :3002 | xargs kill -9 2>/dev/null; vite --port 3002",
    "build": "vite build && node scripts/postbuild-i18n.mjs",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "deploy": "vite build && GOOGLE_APPLICATION_CREDENTIALS=firebase-auth.json firebase deploy",
    "deploy:hosting": "vite build && GOOGLE_APPLICATION_CREDENTIALS=firebase-auth.json firebase deploy --only hosting",
    "deploy:rules": "GOOGLE_APPLICATION_CREDENTIALS=firebase-auth.json firebase deploy --only firestore:rules",
    "deploy:indexes": "GOOGLE_APPLICATION_CREDENTIALS=firebase-auth.json firebase deploy --only firestore:indexes"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@tailwindcss/vite": "^4.2.0",
    "buffer": "6.0.3",
    "firebase": "^12.11.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "^4.2.0",
    "ts-ebml": "2.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
