# OAuth 2.0 client used by the callable functions (exchangeDriveCode / refreshDriveToken)
# to exchange a Drive authorization code for an access token, server-side.
# Lấy từ Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# (cùng client với VITE_GOOGLE_CLIENT_ID ở .env gốc).
#
# Copy file này thành functions/.env và điền giá trị thật. KHÔNG commit functions/.env.
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
