# Google Gemini API
# KHÔNG cấu hình key Gemini ở đây cho client — biến VITE_* sẽ bị nhúng vào
# bundle JS gửi xuống trình duyệt và lộ cho mọi người dùng. Mỗi user tự nhập
# key của họ trong app (menu góc trên phải), lưu ở localStorage.

# Firebase Config - lấy từ Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google OAuth Client ID - lấy từ Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your_oauth_client_id

# Gửi email trực tiếp qua Gmail API — bật 'true' sau khi Google verify scope gmail.send
VITE_FEATURE_GMAIL_SEND=false
